# =========================
# GeoMRV - Environment Template
# =========================
# Copy this file to .env and fill real values locally.
# DO NOT commit .env with secrets.

# App Environment
ENV=dev
APP_NAME=geomrv

# Azure Subscription/Resource Metadata (non-secret)
AZURE_SUBSCRIPTION_ID=your id
AZURE_RESOURCE_GROUP=geomrv-dev
AZURE_REGION=centralindia
AZURE_TENANT_ID=<tenant-id>

# Azure Storage (Blob)
AZURE_STORAGE_ACCOUNT=geomrvstoragedev
AZURE_STORAGE_CONTAINER_EVIDENCE=evidence-packages
AZURE_STORAGE_CONTAINER_CACHE=satellite-data-cache
AZURE_STORAGE_CONNECTION_STRING=<from-key-vault-or-access-keys>
AZURE_STORAGE_ACCOUNT_KEY=<from-key-vault-or-access-keys>

# Key Vault
AZURE_KEY_VAULT_NAME=geomrv-kv
AZURE_KEY_VAULT_URI=key_vault_uri

# Key Vault Secret Name Mapping (use these exact secret names in Azure Key Vault)
# AZURE_STORAGE_ACCOUNT            -> azure-storage-account-name
# AZURE_STORAGE_ACCOUNT_KEY        -> azure-storage-account-key
# AZURE_STORAGE_CONNECTION_STRING  -> azure-storage-connection-string
# APPINSIGHTS_CONNECTION_STRING    -> appinsights-connection-string
# POSTGRES_HOST                    -> postgres-host
# POSTGRES_PORT                    -> postgres-port
# POSTGRES_DB                      -> postgres-db
# POSTGRES_USER                    -> postgres-user
# POSTGRES_PASSWORD                -> postgres-password
# GOOGLE_EARTH_ENGINE_CREDENTIALS  -> google-earth-engine-credentials

# Application Insights
APPINSIGHTS_CONNECTION_STRING=<from-application-insights-overview>

# PostgreSQL (Azure Database for PostgreSQL)
POSTGRES_HOST=connection string
POSTGRES_PORT=5432
POSTGRES_DB=geomrv_dev
POSTGRES_USER=admin
POSTGRES_PASSWORD=<strong-password>
POSTGRES_SSLMODE=require

# Google Earth Engine
GOOGLE_EARTH_ENGINE_CREDENTIALS=<path-to-credentials-json-or-config>
GEE_PROJECT=<your-gee-cloud-project-id-or-leave-blank>
